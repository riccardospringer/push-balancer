# ──────────────────────────────────────────────────────────────
# Push Balancer — Environment Variables
# Copy this file to .env and fill in the values.
# The server loads .env automatically at startup (no python-dotenv needed).
# Lines starting with # are ignored.
# ──────────────────────────────────────────────────────────────


# ── Required ──────────────────────────────────────────────────

# Master kill switch for paid external APIs in the active runtime.
# Leave at 0 unless a deployment explicitly needs paid OpenAI/Adobe features.
PAID_EXTERNAL_APIS_ENABLED=0

# Master switch for autonomous background polling/training/warmup loops.
# Keep at 0 to avoid continuous network and compute load; endpoints fall back
# to on-demand fetching or analysis where available.
BACKGROUND_AUTOMATIONS_ENABLED=0

# Active outbound health probes. Keep at 0 to stop continuous sitemap checks;
# /api/health remains available and reports passive runtime state.
HEALTH_ACTIVE_CHECKS_ENABLED=0

# Economy mode defaults to on for Render and pushes the runtime into a cheap
# profile. It disables live push polling and external research-context fetches
# unless they are explicitly re-enabled.
ECONOMY_MODE=1
PUSH_LIVE_FETCH_ENABLED=0
LIVE_FEED_FALLBACK_ENABLED=0
RESEARCH_EXTERNAL_CONTEXT_ENABLED=0
ARTICLE_PREDICTION_ENRICHMENT_ENABLED=0
# Browser-Ratings are accepted by the Teams worker only while this fresh.
PUSH_BALANCER_CAPTURED_SCORE_MAX_AGE_SECONDS=180
TAGESPLAN_ON_DEMAND_BUILD_ENABLED=0

# Microsoft Teams / Power Automate recommendation alerts.
# Keep disabled unless editorial approval and the Teams flow are configured.
# Only the webhook URL is a secret — set it in the environment, never commit it.
PUSH_TEAMS_ALERTS_ENABLED=0
PUSH_TEAMS_WEBHOOK_URL=
# Interne Score-API: nur serverseitig und erst nach dokumentierter Freigabe aktivieren.
# Der Key bleibt ein Runtime-Secret. Bei Aktivierung gibt es keinen lokalen Score-Fallback.
PUSH_BALANCER_SCORE_API_ENABLED=0
PUSH_BALANCER_SCORE_API_BASE_URL=
PUSH_BALANCER_SCORE_API_KEY=
PUSH_BALANCER_SCORE_API_TIMEOUT_SECONDS=2.5
PUSH_BALANCER_SCORE_API_CACHE_TTL_SECONDS=45
PUSH_BALANCER_SCORE_API_MAX_AGE_SECONDS=900
PUSH_BALANCER_SCORE_API_MAX_CONCURRENCY=16
PUSH_BALANCER_SCORE_API_MAX_RETRIES=1
PUSH_TEAMS_MIN_SCORE=75
# Teams-Reife-Schwelle (0-100). PUSH_TEAMS_MIN_TEAMS_SCORE ist bevorzugt,
# PUSH_TEAMS_MIN_ALERT_SCORE bleibt als Alias erhalten.
PUSH_TEAMS_MIN_TEAMS_SCORE=78
PUSH_TEAMS_SCORE_ONLY_MODE=0
PUSH_TEAMS_CANDIDATE_LIMIT=80
PUSH_TEAMS_MIN_OR=5.0
PUSH_TEAMS_MIN_MINUTES_SINCE_LAST_PUSH=30
# Legacy-Wert fuer nicht-unabhaengigen Betrieb; verifiziertes Breaking umgeht
# den globalen Teams-Cooldown, aber nie Ruhezeit, Qualitaet oder Teams-Dubletten.
PUSH_TEAMS_BREAKING_MIN_MINUTES_SINCE_LAST_PUSH=45
# PUSH_TEAMS_REALERT_COOLDOWN_MINUTES ist bevorzugt; ALERT_COOLDOWN_MINUTES Alias.
PUSH_TEAMS_REALERT_COOLDOWN_MINUTES=90
PUSH_TEAMS_GLOBAL_COOLDOWN_MINUTES=30
# Nach einem gesendeten Teams-Hinweis: ab Cooldown-Ende Schwelle 80, danach
# linear bis Minute 90 auf den Basiswert 75 zurueck. Nie hoeher als 80.
PUSH_TEAMS_POST_SEND_THRESHOLD_ENABLED=1
PUSH_TEAMS_POST_SEND_PEAK_SCORE=80
PUSH_TEAMS_POST_SEND_DECAY_MINUTES=90
# Strikt >80 lockert nur weiche Qualitaets-/Ermuedungsgates. Ruhezeit,
# Slot, Cooldown, Fakten, Aktualitaet, Ressort und Dubletten bleiben hart.
PUSH_TEAMS_HIGH_SCORE_ALWAYS_THRESHOLD=80
# Teams-Hinweise folgen fest ihrem eigenen Tageszaehler und Cooldown.
# Live-Pushes werden nur verglichen und sperren keine Teams-Empfehlung.
# Derselbe Artikel und dasselbe Thema werden ueber die Teams-Historie gesperrt.
PUSH_TEAMS_REALERT_SCORE_DELTA=8
PUSH_TEAMS_REALERT_OR_DELTA=0.75
# Allow-Liste der erlaubten Ressorts. Sport durchlaeuft zusaetzlich ein Ereignis-
# und Wochentag-/Zeitfenster-Gate; Routine-Sport wird nicht empfohlen.
PUSH_TEAMS_ALLOWED_SECTIONS=News,Politik,Wirtschaft,Geld,Regional,Digital,Unterhaltung,Sport
# Hart ausgeschlossene Ressorts — leer = kein pauschaler Ressort-Ausschluss.
PUSH_TEAMS_EXCLUDED_SECTIONS=
# Ruhezeit: in diesem Fenster werden keine Teams-Hinweise gesendet.
PUSH_TEAMS_QUIET_HOURS_START=00:00
PUSH_TEAMS_QUIET_HOURS_END=05:30
# Verbindlicher Laufzeitplan: taeglich 06:15/06:45 sowie :15/:45 in jeder roten
# oder gelben Wochentagsstunde. Gute :45-Reservezeiten ergaenzen auf mindestens
# 15; starke Montage enthalten alle 18 Pflichtfenster.
# Unter Push-Score 75 sowie bei harten Fakten-/Dubletten-Sperren wird nie erzwungen.
PUSH_TEAMS_TARGET_PUSHES_PER_DAY=15
PUSH_TEAMS_MIN_ALERTS_PER_DAY=15
PUSH_TEAMS_MAX_ALERTS_PER_DAY=18
PUSH_TEAMS_DAILY_PLAN_MIN_ITEMS=15
PUSH_TEAMS_DAILY_PLAN_MAX_ITEMS=18
# Um :15 wird die API-Top-1-Meldung geprueft; um :45 werden Scores neu geladen,
# Teams-Dubletten entfernt und Top 1 erneut bestimmt. Zum Mindestziel fehlende
# Stunden sind Recovery-Fenster. Push-Score 75 und alle harten Gates bleiben bestehen.
PUSH_TEAMS_SLOT_GATE_ENABLED=1
PUSH_TEAMS_SLOT_DEADLINE_MINUTE=45
PUSH_TEAMS_PEAK_SLOT_MIN_OR=6.0
PUSH_TEAMS_EARLY_EXCEPTIONAL_SCORE=88
PUSH_TEAMS_EARLY_EXCEPTIONAL_ALERT_SCORE=86
PUSH_TEAMS_EARLY_EXCEPTIONAL_EDITORIAL_SCORE=80
# Im faelligen Mindestfenster bleibt der normale Push-Score von 75 hart.
# Alert- und CvD-Werte sind Referenzen fuer Rangfolge und Gegencheck, keine
# eigenstaendigen Mengen-Blocker.
PUSH_TEAMS_DEADLINE_FALLBACK_MIN_SCORE=75
PUSH_TEAMS_DEADLINE_FALLBACK_MIN_ALERT_SCORE=73
PUSH_TEAMS_DEADLINE_FALLBACK_MIN_EDITORIAL_SCORE=69
PUSH_TEAMS_DAILY_SCHEDULE_SEND_ENABLED=0
PUSH_TEAMS_DAILY_SCHEDULE_SEND_TIME=05:45
# 17 lokale Spezialpruefer. Bis Incident-, Privacy-, DPO-, Product- und Legal-
# Freigabe deaktiviert lassen.
PUSH_TEAMS_AGENT_REVIEW_ENABLED=0
PUSH_TEAMS_AGENT_REVIEW_MIN_EVIDENCE_APPROVALS=3
PUSH_TEAMS_AGENT_REVIEW_MIN_CONSENSUS_SCORE=60
PUSH_TEAMS_MIN_RECOMMENDATION_QUALITY=72
PUSH_TEAMS_AGENT_REVIEW_MAX_LATENCY_MS=50
PUSH_TEAMS_DYNAMIC_THRESHOLD_ENABLED=1
# Legacy-Schalter; 0 ist verbindlich, weil Rueckstand Qualitaet nie absenkt.
PUSH_TEAMS_DYNAMIC_THRESHOLD_MAX_DROP=0
PUSH_TEAMS_DYNAMIC_THRESHOLD_MAX_RISE=14
PUSH_TEAMS_ACTIVE_HOURS_START=6
PUSH_TEAMS_ACTIVE_HOURS_END=23
# Nur belastbare (Modell-)Prognosen zulassen? Standard: false (Fallback erlaubt,
# wird aber nie positiv gewichtet).
PUSH_TEAMS_REQUIRE_VALID_PREDICTION=0
PUSH_TEAMS_REQUIRE_ARTICLE_FORECAST=1
# Konstante Fake-/Default-Prognosen erkennen (z. B. globaler Schnitt 4.77 %).
# Wiederholt sich ein OR-Wert ueber das Feld, gilt er als Default (nicht belastbar).
PUSH_TEAMS_KNOWN_DEFAULT_FORECASTS=4.77
PUSH_TEAMS_CONSTANT_FORECAST_MIN_FIELD=3
PUSH_TEAMS_KNOWN_DEFAULT_MIN_FIELD=2
# "Klarer Gewinner"-Regel: unsicheres Feld (Top-Kandidat nur knapp vorn und
# selbst nicht eindeutig stark) -> kein Alert. Breaking/starke Kandidaten ausgenommen.
PUSH_TEAMS_MIN_SELECTION_MARGIN=5.0
PUSH_TEAMS_SELECTION_CLEAR_EDITORIAL_BUFFER=6.0
# Der Push-Score dominiert die Auswahl. Erwartete Oeffnungen duerfen nur unter
# bereits starken Kandidaten mitentscheiden und hoechstens 15 % Gewicht erhalten.
PUSH_TEAMS_VISIT_OPTIMIZATION_ENABLED=1
PUSH_TEAMS_VISIT_SELECTION_WEIGHT=0.10
PUSH_TEAMS_BREAKING_OVERRIDE=1
PUSH_TEAMS_BREAKING_MIN_SCORE=72
PUSH_TEAMS_CHECK_INTERVAL_SECONDS=60

# OpenAI API key — only used for explicitly enabled manual generation or
# prediction scoring features.
OPENAI_API_KEY=sk-...

# Enables the higher-quality LLM path for manual push-title generation.
# Without this flag the endpoint uses the local fallback generator.
OPENAI_TITLE_GENERATION_ENABLED=0
OPENAI_TITLE_GENERATION_MODEL=gpt-5.6-luna
OPENAI_TITLE_GENERATION_TIMEOUT_S=8.0
OPENAI_TITLE_GENERATION_MAX_TOKENS=600
OPENAI_TITLE_GENERATION_REASONING_EFFORT=none
# Additional hard budget guard. Keep both at 0 to force the local fallback
# even when title generation is enabled.
OPENAI_TITLE_GENERATION_MAX_CALLS_PER_HOUR=0
OPENAI_TITLE_GENERATION_MAX_CALLS_PER_DAY=0

# Keeps the dormant LLM backfill worker off unless it is explicitly required.
OPENAI_BACKFILL_ENABLED=0

# Hard cost guard for OR prediction heuristics. Prediction-time OpenAI usage is
# disabled by default and only active when both this flag and the global
# PAID_EXTERNAL_APIS_ENABLED switch are enabled.
OPENAI_PREDICTION_SCORING_ENABLED=0
OPENAI_PREDICTION_SCORING_MODEL=gpt-4o-mini
OPENAI_PREDICTION_SCORING_TIMEOUT_S=4.0
OPENAI_PREDICTION_SCORING_MAX_TOKENS=60
OPENAI_PREDICTION_SCORING_CACHE_TTL_S=3600
# Additional hard budget guard. Keep both at 0 to disable paid scoring even
# when prediction scoring is otherwise enabled.
OPENAI_PREDICTION_SCORING_MAX_CALLS_PER_HOUR=0
OPENAI_PREDICTION_SCORING_MAX_CALLS_PER_DAY=0

# Base URL of the BILD Push Statistics API.
# Only reachable from the internal Axel Springer network or via VPN.
PUSH_API_BASE=https://push-frontend.bildcms.de


# ── Context & Sports APIs (optional) ──────────────────────────

# Football-Data.org API key — fetches Bundesliga and Champions League
# fixtures to enrich sport push timing context.
# Register free at https://www.football-data.org/
FOOTBALL_DATA_KEY=

# The Odds API key — fetches live betting odds as a sport relevance signal.
# Register at https://the-odds-api.com/
ODDS_API_KEY=


# ── Adobe Analytics (optional) ────────────────────────────────
# If all three are set and ADOBE_TRAFFIC_ENABLED=1, the Adobe Traffic Worker starts and enriches
# push history with traffic source breakdowns (push / home / social /
# search / direct) via fuzzy headline matching.
ADOBE_TRAFFIC_ENABLED=0

# OAuth2 Client Credentials for Adobe Analytics API.
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=

# Adobe Analytics company ID (report suite company).
# Default value matches the Axel Springer BILD report suite.
ADOBE_GLOBAL_COMPANY_ID=axelsp2


# ── Data Sources ───────────────────────────────────────────────

# BILD news sitemap URL — used by the Research Worker to discover
# candidate articles for the Tagesplan recommendations.
BILD_SITEMAP_URL=https://www.bild.de/sitemap-news.xml


# ── Render Deployment / Push-Data Sync ────────────────────────

# Shared secret for the push data relay between the local Mac server
# and the Render deployment. Both sides must use the same value.
# Must be set to a strong random string in every environment that exposes
# POST /api/pushes/sync. Leave empty only if you do not use relay sync.
PUSH_SYNC_SECRET=

# URL of the Render deployment. When set on the local server, push data
# is relayed to the Render instance via POST /api/pushes/sync so that
# the cloud instance stays current without direct BILD API access.
# Leave empty if running locally only.
RENDER_SYNC_URL=


# ── Server ─────────────────────────────────────────────────────

# Port the HTTP server listens on.
PORT=8050

# Host the server binds to. Use 0.0.0.0 to accept connections from
# all interfaces (required in Docker / Render).
BIND_HOST=0.0.0.0

# Set to 1 to disable SSL certificate verification for outbound requests.
# Use only in controlled development environments — never in production.
ALLOW_INSECURE_SSL=0


# ── Security ───────────────────────────────────────────────────

# API key for admin endpoints (POST /api/ml/retrain, /api/gbrt/retrain,
# /api/gbrt/force-promote, /api/ml/monitoring/tick).
# Send via X-Admin-Key header.
# Must be set to a strong random value before enabling admin mutation endpoints.
# Generieren: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=

# API key for read-only downstream consumers (GET /api/v1/recommendations,
# GET /api/v1/articles, GET /api/v1/scores). Prefer Authorization: Bearer.
# X-Consumer-Key remains supported for simple internal clients.
# Leave empty to keep the consumer API disabled.
CONSUMER_API_KEY=

# Restrict non-exempt routes to the internal AS/VPN egress IP ranges.
# On Render this is intended for internal-only deployments.
INTERNAL_ACCESS_ENABLED=0

# Comma-separated CIDR allowlist for internal browser/API access.
# Examples:
# INTERNAL_ACCESS_ALLOWED_CIDRS=127.0.0.1/32,::1/128,203.0.113.14/32
INTERNAL_ACCESS_ALLOWED_CIDRS=127.0.0.1/32,::1/128

# Routes that stay reachable even when internal access is enabled.
# Keep /api/health for platform health checks. /api/v1 stays externally
# reachable for consumer apps, but every /api/v1 route still requires auth.
INTERNAL_ACCESS_EXEMPT_PATHS=/api/health,/api/v1

# Set to 1 to enable development mode.
# In dev mode: CORS tunnel wildcards (ngrok, localtunnel, Cloudflare) are allowed.
# In production: leave empty or 0.
DEV_MODE=0


# ── Frontend / Package Registry (optional) ────────────────────

# GitHub Package Registry token for the private Editorial One UI package.
# Needed only when installing @spring-media/editorial-one-ui locally from the
# spring-media GitHub organization package registry.
NPM_TOKEN=


# ── Runtime (optional) ────────────────────────────────────────

# Override the SQLite path, e.g. to a persistent Render disk mount.
DB_PATH=

# Maximum age of push rows loaded from SQLite into memory.
# Helps keep startup and background analysis bounded on large databases.
PUSH_DB_MAX_DAYS=90

# Maximum number of push rows loaded from SQLite into memory.
# Use lower values on smaller cloud instances to reduce RAM spikes.
PUSH_DB_MAX_ROWS=

# Optional path to a local or mounted startup seed file.
# Keep it out of the repository and use only sanitized data.
PUSH_SNAPSHOT_PATH=
