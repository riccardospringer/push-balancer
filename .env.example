# ──────────────────────────────────────────────────────────────
# Push Balancer — Environment Variables
# Copy this file to .env and fill in the values.
# The server loads .env automatically at startup (no python-dotenv needed).
# Lines starting with # are ignored.
# ──────────────────────────────────────────────────────────────


# ── Required ──────────────────────────────────────────────────

# Master kill switch for paid external APIs in the active runtime.
# Leave at 0 unless a deployment explicitly needs paid OpenAI/Adobe features.
PAID_EXTERNAL_APIS_ENABLED=0

# Master switch for autonomous background polling/training/warmup loops.
# Keep at 0 to avoid continuous network and compute load; endpoints fall back
# to on-demand fetching or analysis where available.
BACKGROUND_AUTOMATIONS_ENABLED=0

# Active outbound health probes. Keep at 0 to stop continuous sitemap checks;
# /api/health remains available and reports passive runtime state.
HEALTH_ACTIVE_CHECKS_ENABLED=0

# Economy mode defaults to on for Render and pushes the runtime into a cheap
# profile. It disables live push polling and external research-context fetches
# unless they are explicitly re-enabled.
ECONOMY_MODE=1
PUSH_LIVE_FETCH_ENABLED=0
LIVE_FEED_FALLBACK_ENABLED=0
RESEARCH_EXTERNAL_CONTEXT_ENABLED=0
ARTICLE_PREDICTION_ENRICHMENT_ENABLED=0
TAGESPLAN_ON_DEMAND_BUILD_ENABLED=0

# OpenAI API key — only used for explicitly enabled manual generation or
# prediction scoring features.
OPENAI_API_KEY=sk-...

# Enables the higher-quality LLM path for manual push-title generation.
# Without this flag the endpoint uses the local fallback generator.
OPENAI_TITLE_GENERATION_ENABLED=0
OPENAI_TITLE_GENERATION_MODEL=gpt-4o-mini
OPENAI_TITLE_GENERATION_TIMEOUT_S=8.0
OPENAI_TITLE_GENERATION_MAX_TOKENS=320
# Additional hard budget guard. Keep both at 0 to force the local fallback
# even when title generation is enabled.
OPENAI_TITLE_GENERATION_MAX_CALLS_PER_HOUR=0
OPENAI_TITLE_GENERATION_MAX_CALLS_PER_DAY=0

# Keeps the dormant LLM backfill worker off unless it is explicitly required.
OPENAI_BACKFILL_ENABLED=0

# Hard cost guard for OR prediction heuristics. Prediction-time OpenAI usage is
# disabled by default and only active when both this flag and the global
# PAID_EXTERNAL_APIS_ENABLED switch are enabled.
OPENAI_PREDICTION_SCORING_ENABLED=0
OPENAI_PREDICTION_SCORING_MODEL=gpt-4o-mini
OPENAI_PREDICTION_SCORING_TIMEOUT_S=4.0
OPENAI_PREDICTION_SCORING_MAX_TOKENS=60
OPENAI_PREDICTION_SCORING_CACHE_TTL_S=3600
# Additional hard budget guard. Keep both at 0 to disable paid scoring even
# when prediction scoring is otherwise enabled.
OPENAI_PREDICTION_SCORING_MAX_CALLS_PER_HOUR=0
OPENAI_PREDICTION_SCORING_MAX_CALLS_PER_DAY=0

# Base URL of the BILD Push Statistics API.
# Only reachable from the internal Axel Springer network or via VPN.
PUSH_API_BASE=https://push-frontend.bildcms.de


# ── Context & Sports APIs (optional) ──────────────────────────

# Football-Data.org API key — fetches Bundesliga and Champions League
# fixtures to enrich sport push timing context.
# Register free at https://www.football-data.org/
FOOTBALL_DATA_KEY=

# The Odds API key — fetches live betting odds as a sport relevance signal.
# Register at https://the-odds-api.com/
ODDS_API_KEY=


# ── Adobe Analytics (optional) ────────────────────────────────
# If all three are set and ADOBE_TRAFFIC_ENABLED=1, the Adobe Traffic Worker starts and enriches
# push history with traffic source breakdowns (push / home / social /
# search / direct) via fuzzy headline matching.
ADOBE_TRAFFIC_ENABLED=0

# OAuth2 Client Credentials for Adobe Analytics API.
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=

# Adobe Analytics company ID (report suite company).
# Default value matches the Axel Springer BILD report suite.
ADOBE_GLOBAL_COMPANY_ID=axelsp2


# ── Data Sources ───────────────────────────────────────────────

# BILD news sitemap URL — used by the Research Worker to discover
# candidate articles for the Tagesplan recommendations.
BILD_SITEMAP_URL=https://www.bild.de/sitemap-news.xml


# ── Render Deployment / Push-Data Sync ────────────────────────

# Shared secret for the push data relay between the local Mac server
# and the Render deployment. Both sides must use the same value.
# Must be set to a strong random string in every environment that exposes
# POST /api/pushes/sync. Leave empty only if you do not use relay sync.
PUSH_SYNC_SECRET=

# URL of the Render deployment. When set on the local server, push data
# is relayed to the Render instance via POST /api/pushes/sync so that
# the cloud instance stays current without direct BILD API access.
# Leave empty if running locally only.
RENDER_SYNC_URL=


# ── Server ─────────────────────────────────────────────────────

# Port the HTTP server listens on.
PORT=8050

# Host the server binds to. Use 0.0.0.0 to accept connections from
# all interfaces (required in Docker / Render).
BIND_HOST=0.0.0.0

# Set to 1 to disable SSL certificate verification for outbound requests.
# Use only in controlled development environments — never in production.
ALLOW_INSECURE_SSL=0


# ── Security ───────────────────────────────────────────────────

# API key for admin endpoints (POST /api/ml/retrain, /api/gbrt/retrain,
# /api/gbrt/force-promote, /api/ml/monitoring/tick).
# Send via X-Admin-Key header.
# Must be set to a strong random value before enabling admin mutation endpoints.
# Generieren: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=

# Restrict non-exempt routes to the internal AS/VPN egress IP ranges.
# On Render this is intended for internal-only deployments.
INTERNAL_ACCESS_ENABLED=0

# Comma-separated CIDR allowlist for internal browser/API access.
# Examples:
# INTERNAL_ACCESS_ALLOWED_CIDRS=127.0.0.1/32,::1/128,203.0.113.14/32
INTERNAL_ACCESS_ALLOWED_CIDRS=127.0.0.1/32,::1/128

# Routes that stay reachable even when internal access is enabled.
# Keep /api/health unless your platform health checks use a different path.
INTERNAL_ACCESS_EXEMPT_PATHS=/api/health

# Set to 1 to enable development mode.
# In dev mode: CORS tunnel wildcards (ngrok, localtunnel, Cloudflare) are allowed.
# In production: leave empty or 0.
DEV_MODE=0


# ── Frontend / Package Registry (optional) ────────────────────

# GitHub Package Registry token for the private Editorial One UI package.
# Needed only when installing @spring-media/editorial-one-ui locally from the
# spring-media GitHub organization package registry.
NPM_TOKEN=


# ── Runtime (optional) ────────────────────────────────────────

# Override the SQLite path, e.g. to a persistent Render disk mount.
DB_PATH=

# Maximum age of push rows loaded from SQLite into memory.
# Helps keep startup and background analysis bounded on large databases.
PUSH_DB_MAX_DAYS=90

# Maximum number of push rows loaded from SQLite into memory.
# Use lower values on smaller cloud instances to reduce RAM spikes.
PUSH_DB_MAX_ROWS=

# Optional path to a local or mounted startup seed file.
# Keep it out of the repository and use only sanitized data.
PUSH_SNAPSHOT_PATH=
